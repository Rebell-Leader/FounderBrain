# .env.example — Helm
# No environment variables are required for the public deterministic sandbox.
# Never commit a real .env file or send these values to the browser.

# Optional, private demo-only copy refresh. POST /api/sandbox/refresh requires
# both values; leave both UNSET in the judge deployment so the route returns 503.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
SANDBOX_REFRESH_TOKEN=
