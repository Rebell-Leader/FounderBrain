# .env.example — Helm
# Copy to .env and fill. Never commit .env. Secrets in prod go to the platform's
# secret manager (Vercel env / GCP Secret Manager), not files.

# ---- LLM ----
LLM_PROVIDER=openai                 # openai | gemini (failover flag, guardrails L5)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6                # synthesis / cross-reference / drafts
OPENAI_LIGHT_MODEL=gpt-5.6-luna     # evaluate for high-volume classification
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional private demo endpoint: POST /api/sandbox/refresh requires this token
# in x-helm-demo-token and never exposes it to the browser.
SANDBOX_REFRESH_TOKEN=
# Gemini adapter (week 2; leave empty for hackathon week 1)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=europe-west1
GEMINI_MODEL=

# ---- Database (Supabase Postgres + pgvector) ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/helm
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only

# ---- Gmail (data source; OAuth consent screen in TESTING mode, see checklist §2.1) ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ---- Stripe: TWO hats, do not mix ----
# Hat 1: the FOUNDER'S account as a data source (restricted READ-ONLY key pasted per-user in-app;
# no env var — stored encrypted per connection). Webhook endpoint secret:
STRIPE_SOURCE_WEBHOOK_SECRET=
# Hat 2: Helm's own billing (week 3)
STRIPE_BILLING_SECRET_KEY=
STRIPE_BILLING_WEBHOOK_SECRET=
STRIPE_BILLING_PRICE_ID_FOUNDING=   # €29/mo founding member price

# ---- Crypto ----
TOKEN_ENCRYPTION_KEY=               # 32-byte base64 (libsodium sealed box) for OAuth tokens & stripe keys

# ---- Guardrail operational controls (guardrails L6) ----
RUN_COST_BUDGET_USD=0.40
MAX_AGENT_SENDS_PER_DAY=15
SEND_HOURS_LOCAL=07-20
KILL_SWITCH_SENDS=false
KILL_SWITCH_WATCHLIST=false
FORCE_TEMPLATE_DRAFTS=false

# ---- Modes ----
SANDBOX_ENABLED=true                # judges' path; stubs searchWeb + gmail send
NEXT_PUBLIC_APP_URL=http://localhost:3000
INGEST_EMAIL_ADDRESS=               # notes forwarding address (checklist §1)

# ---- Cron ----
CRON_SECRET=                        # protects /api/cron/nightly
